# ══════════════════════════════════════════════════════════════════
# 토닥 — 환경변수 예시 (커밋 가능한 참고 파일)
# ──────────────────────────────────────────────────────────────────
# 사용 방법: 이 파일을 복사해 .env.local을 만든 뒤 실제 값을 채우세요.
#   cp .env.example .env.local
# ══════════════════════════════════════════════════════════════════

# ── Supabase (Supabase Dashboard > Settings > API) ────────────────
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── TossPayments (개발: test_ck_ / 운영: live_ck_) ─────────────────
EXPO_PUBLIC_TOSS_CLIENT_KEY=test_ck_...

# ── 앱 설정 ───────────────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=todak://
EXPO_PUBLIC_APP_ENV=development

# ── 주의: 아래 키들은 서버 전용 — EXPO_PUBLIC 접두사 사용 금지! ──────
# Supabase Edge Functions > Secrets 에 저장:
#   eas secret:create --scope project --name TOSS_SECRET_KEY  --value "test_sk_..."
#   eas secret:create --scope project --name DAILY_API_KEY    --value "..."
#
# Supabase Dashboard > Edge Functions > Secrets 에도 별도 설정 필요:
#   TOSS_SECRET_KEY, DAILY_API_KEY, SUPABASE_SERVICE_ROLE_KEY (자동 주입)
